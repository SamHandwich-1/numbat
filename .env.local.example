# Supabase (cloud project named "numbat")
# Copy to .env.local and fill in. .env.local is gitignored.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Single-operator auth gate. Slice 2 wires this into the Next.js middleware.
NUMBAT_AUTH_TOKEN=

# Anthropic API key. Optional — the Claude Agent SDK reuses ~/.claude/.credentials.json
# from `claude login` automatically. Set this only to override.
ANTHROPIC_API_KEY=
